#include <iostream>
using namespace std;

int main(){
    string cmd;

    while(cin>>cmd){
        if(cmd=="add"){
            int a,b; cin>>a>>b;
            cout<<a+b<<endl;
        }
        else if(cmd=="exit")
            break;
    }
